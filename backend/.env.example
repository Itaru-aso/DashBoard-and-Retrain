# shisui app_ver2 バックエンド 環境変数サンプル
# 実際の値・シークレットは .env に記載し、コミットしない（.gitignore 済み）。
# 変数の意味は .kiro/steering/tech.md「環境変数」を参照。

# --- DB 接続（2エンジン: ver2=読み書き / 業者検査 DB=読み取り専用） ---
DATABASE_URL=postgresql+psycopg2://shisui:shisui@localhost:5432/ver2
INSPECTION_DATABASE_URL=postgresql+psycopg2://readonly:readonly@localhost:5433/app_db

# --- 実行モード ---
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Basic 認証（単一共有クレデンシャル。有効時はパス必須） ---
ENABLE_BASIC_AUTH=false
BASIC_AUTH_USER=shisui
BASIC_AUTH_PASS=

# --- 再学習（training/ 連携。subprocess 起動の CWD・ONNX 出力先・python 実行ファイル） ---
TRAINING_DIR=D:\0032011\GitLab\shisui\app_ver2\training
TRAINING_MODEL_DIR=D:\0032011\GitLab\shisui\app_ver2\training\6_model
TRAINING_PYTHON=python
# 未設定なら config.yaml 自身の imagenet_train_path を使う（環境ごとにパスが異なる場合のみ設定）。
TRAINING_IMAGENET_PATH=
# 未設定なら config.yaml 自身のパス一式（pretraining_dir 等）を使う（Docker 等でのみ設定）。
TRAINING_DATA_ROOT=

# --- 日次集計ジョブ（アプリ内スケジューラ） ---
AGG_RUN_TIME=02:00
AGG_WINDOW_DAYS=7

# --- 逸脱判定ジョブ（アプリ内スケジューラ） ---
BREACH_EVAL_ENABLED=false
BREACH_EVAL_TIME=03:00
BREACH_EVAL_WINDOW_DAYS=7
